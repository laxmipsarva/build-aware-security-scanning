{
  "name": "build-aware-security-scanning",
  "version": "1.1.0",
  "description": "CLI toolkit to discover API endpoints and test for SQL injection and API vulnerabilities in Next.js and Express apps",
  "type": "module",
  "main": "index.mjs",
  "exports": {
    ".": "./index.mjs",
    "./list-endpoints": "./src/list-endpoints.mjs",
    "./test-sqli": "./src/test-sqli.mjs",
    "./test-api": "./src/test-api.mjs"
  },
  "bin": {
    "bass-list": "./bin/list-endpoints.mjs",
    "bass-sqli": "./bin/test-sqli.mjs",
    "bass-api":  "./bin/test-api.mjs"
  },
  "scripts": {
    "test": "node bin/list-endpoints.mjs . && echo 'list-endpoints OK'"
  },
  "keywords": [
    "security",
    "sql-injection",
    "api-testing",
    "mass-assignment",
    "parameter-pollution",
    "endpoint-discovery",
    "nextjs",
    "express",
    "penetration-testing",
    "sqli",
    "owasp"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
